// _meta/core/config.jsonc
// ====================================================================
// Machine-readable mirror of _meta/core/conventions.md.
//
// If this file disagrees with conventions.md, conventions.md wins.
// Re-derive from conventions.md; do not drift.
//
// Consumed by scripts under _meta/features/ and _meta/lib/.
// Parse via _meta/lib/config_loader.py (stdlib only).
// ====================================================================
{
  "_self": {
    "version": "2.4",
    "conventions_path": "_meta/core/conventions.md",
    "last_updated": "2026-04-23",
    "format": "jsonc",
    "loader": "_meta/lib/config_loader.py"
  },

  // ------------------------------------------------------------------ //
  // PROTECTED — automation must never modify anything listed here.     //
  // ------------------------------------------------------------------ //
  "protected": {
    "directories": [
      ".git",
      ".foam",
      ".vscode",
      ".claude",
      "attachments",
      "node_modules",
      "_meta"
    ],
    "files": [],
    "regions": {
      "foam_link_references": {
        "start_marker": "[//begin]: # \"Autogenerated link references for markdown compatibility\"",
        "end_marker": "[//end]: # \"Autogenerated link references\"",
        "managed_by": "Foam",
        "rule": "preserve-verbatim"
      }
    },
    "exceptions": {
      ".foam/templates/": "User-managed. One-time manual edits only; log in _meta/changelog.md."
    }
  },

  // ------------------------------------------------------------------ //
  // APPEND-ONLY FILES (AI may add; must mark additions)                //
  // Agents may append new lines but never reorder or rewrite existing  //
  // content. Every AI-added line must end with "(added by AI agent)".  //
  // Nancy (secretary authority) additionally may flip an existing      //
  // checkbox from `- [ ]` to `- [x]` in todo.md, appending              //
  // "(marked done by AI agent YYYY-MM-DD)". No other edit-in-place     //
  // is permitted. See conventions.md §1b.                              //
  // ------------------------------------------------------------------ //
  "append_only": {
    "files": ["inbox.md", "todo.md"],
    "marker_suffix": "(added by AI agent)",
    "secretary_todo_done_marker": "(marked done by AI agent {YYYY-MM-DD})"
  },

  // ------------------------------------------------------------------ //
  // CANONICAL FOLDERS                                                  //
  // Empty folders are allowed (journal/, 4-atlas/, 5-cards/).          //
  // No max_depth; project folders may nest freely.                     //
  // _archive/ has no internal-structure rules — its contents may be    //
  // organized any way the user likes.                                  //
  // ------------------------------------------------------------------ //
  "canonical_folders": {
    "top_level": [
      "journal",
      "1-projects",
      "2-areas",
      "3-resources",
      "4-atlas",
      "5-cards",
      "_archive",
      "_meta",
      "_secretary"
    ],
    "empty_ok": ["journal", "4-atlas", "5-cards"],
    "no_other_top_level": true
  },

  // ------------------------------------------------------------------ //
  // NAMING                                                             //
  // Only filesystem-illegal characters are rejected. Case, spaces,     //
  // dates, punctuation, leading/trailing dots — all allowed.           //
  // Case-collision within a folder is still forbidden (prevents silent //
  // data loss on case-insensitive filesystems).                        //
  // ------------------------------------------------------------------ //
  "naming": {
    "slug_regex": "^[^/\\\\:*?\"<>|\\x00-\\x1f]+$",
    "case_collision_within_folder": false,
    "file_extension": ".md"
  },

  // ------------------------------------------------------------------ //
  // FRONTMATTER                                                        //
  // Strongly recommended, not required. vault-check warns (not errors) //
  // when recommended keys are missing and re-reminds if the same       //
  // warnings persist for ≥ recheck_interval_hours.                     //
  //                                                                    //
  // agent_auto_correct: when true, admin- OR maintenance-authority    //
  // agents (Claude) may WRITE missing recommended keys directly into   //
  // note files. They must NOT commit — the user reviews `git diff`    //
  // and commits manually.                                              //
  // ------------------------------------------------------------------ //
  "frontmatter": {
    "recommended": ["title", "created"],
    "optional": ["type", "tags", "aliases"],
    "reserved_prefixes": ["foam_"],
    "created_format": "YYYY-MM-DD",
    "agent_auto_correct": false,
    "recheck_interval_hours": 24,

    // Legacy keys, kept for backward compatibility with scripts.
    // required=[] and forbidden=[] mean M1/M2 never fire.
    "required": [],
    "forbidden": []
  },

  // ------------------------------------------------------------------ //
  // AGENT POLICY                                                       //
  // Governs what AI agents (Claude, others) may do autonomously.       //
  // ------------------------------------------------------------------ //
  "agent": {
    // Agents never run git commands (commit, push, branch, tag, reset,
    // merge, rebase, add, mv, rm) unless the user explicitly asks in
    // the current turn. Reading state (status, log, diff) is allowed.
    // Registry features declaring `modifies_git: true` (e.g. rename-
    // note) may be invoked when the user triggers them — the feature
    // invocation IS the explicit authorization.
    "git_autonomy": false,

    // Authority modes — mapped 1:1 to mode files in _meta/modes/.
    // Each mode declares its own authority in its header banner.
    "authority_modes": {
      "inspector": {
        "mode_file": "_meta/modes/inspector.md",
        "may_read": true,
        "may_write_notes": false,
        "may_touch_structure": false,
        "may_invoke_features": ["vault-check"]
      },
      "author": {
        "mode_file": "_meta/modes/capture.md | _meta/modes/work.md",
        "may_read": true,
        "may_write_notes": true,
        "may_touch_structure": false,
        "may_invoke_features": ["vault-check"]
      },
      "maintenance": {
        "mode_file": "_meta/modes/maintenance.md",
        "may_read": true,
        "may_write_notes": true,
        "may_touch_structure": false,
        "may_invoke_features": ["vault-check", "build-book-indexes"],
        "may_auto_correct_frontmatter": true
      },
      "admin": {
        "mode_file": "_meta/modes/admin.md",
        "may_read": true,
        "may_write_notes": true,
        "may_touch_structure": true,
        "may_invoke_features": "*",
        "may_auto_correct_frontmatter": true
      },
      "secretary": {
        "mode_file": "_secretary/NANCY.md",
        "may_read": true,
        "may_write_notes": false,
        "write_scope": "_secretary/**",
        "may_touch_structure": false,
        "may_invoke_features": ["vault-check"],
        "extra_write_permissions": {
          "todo.md": "mark-checkbox-complete-only"
        }
      }
    }
  },

  // ------------------------------------------------------------------ //
  // LINKS                                                              //
  // ------------------------------------------------------------------ //
  "links": {
    "style": "wikilink",
    "slug_unique_vault_wide": true,
    "case_insensitive_resolution": true
  },

  // ------------------------------------------------------------------ //
  // OUTLINE — master Map of Content reachability                       //
  // Every non-archived, non-protected note must be reachable from      //
  // master_moc by following wikilinks. Enforced by vault-check (O1).   //
  //                                                                    //
  // Exempt dirs are now shared with L3 (slug uniqueness) and M6        //
  // (frontmatter warnings) — see `rules.exempt_dirs` below. outline.   //
  // exempt_dirs is kept as a fallback for backward compat.             //
  // ------------------------------------------------------------------ //
  "outline": {
    "master_moc": "outlines",
    "enforce_reachability": true
  },

  // ------------------------------------------------------------------ //
  // RULES — shared exemption lists used by multiple vault-check rules. //
  // Dirs listed here are treated as "outside the vault body": their    //
  // files do NOT participate in L3 slug uniqueness, are NOT required   //
  // to be reachable from the master outline (O1), and are NOT warned   //
  // about for missing recommended frontmatter (M6).                    //
  //                                                                    //
  // `_archive/` — provenance storage; no outline/frontmatter concerns. //
  // `_secretary/` — Nancy's workspace; uses HTML-comment entry headers //
  //   instead of YAML frontmatter, and is grep-organized, not linked.  //
  // ------------------------------------------------------------------ //
  "rules": {
    "exempt_dirs": ["_archive", "_secretary"]
  },

  // ------------------------------------------------------------------ //
  // FEATURES                                                           //
  // Registry lives at _meta/features/registry.jsonc. Each feature is a //
  // self-contained folder with FEATURE.md + entry script.              //
  // ------------------------------------------------------------------ //
  "features": {
    "registry": "_meta/features/registry.jsonc",
    "root": "_meta/features/",
    "shared_lib": "_meta/lib/"
  }
}
